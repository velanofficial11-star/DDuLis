-- =========================
-- FOV Logic
-- =========================
local draggingSlider = false
local currentFov = DEFAULT_FOV

local function fovToAlpha(fov)
	return (fov - MIN_FOV) / (MAX_FOV - MIN_FOV)
end

local function alphaToFov(alpha)
	return MIN_FOV + (MAX_FOV - MIN_FOV) * alpha
end

local function updateUiFromFov()
	local alpha = fovToAlpha(currentFov)
	sliderFill.Size = UDim2.new(alpha, 0, 1, 0)
	knob.Position = UDim2.new(alpha, 0, 0.5, 0)

	local rounded = math.floor(currentFov + 0.5)
	currentLabel.Text = ("Current FOV: %d"):format(rounded)
	inputBox.Text = tostring(rounded)
end

local function setFov(value)
	currentFov = clamp(value, MIN_FOV, MAX_FOV)
	if camera then
		camera.FieldOfView = currentFov
	end
	updateUiFromFov()
end

local function setFovFromSliderX(absX)
	local rel = (absX - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X
	local alpha = clamp(rel, 0, 1)
	setFov(alphaToFov(alpha))
end

sliderBg.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		draggingSlider = true
		setFovFromSliderX(input.Position.X)
	end
end)

sliderBg.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		draggingSlider = false
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if not draggingSlider then
		return
	end
	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
		setFovFromSliderX(input.Position.X)
	end
end)

applyBtn.MouseButton1Click:Connect(function()
	task.spawn(pressAnim, applyBtn)
	local n = tonumber(inputBox.Text)
	if n then
		setFov(n)
	else
		updateUiFromFov()
	end
end)

resetBtn.MouseButton1Click:Connect(function()
	task.spawn(pressAnim, resetBtn)
	setFov(DEFAULT_FOV)
end)

inputBox.FocusLost:Connect(function(enterPressed)
	if not enterPressed then
		return
	end
	local n = tonumber(inputBox.Text)
	if n then
		setFov(n)
	else
		updateUiFromFov()
	end
end)

-- =========================
-- Minimize / Open
-- =========================
local function minimize()
	main.Visible = false
	openBtn.Visible = true
	openBtn.Position = main.Position
end

local function openPanel()
	main.Visible = true
	openBtn.Visible = false
end

minBtn.MouseButton1Click:Connect(function()
	task.spawn(pressAnim, minBtn)
	minimize()
end)

openBtn.MouseButton1Click:Connect(function()
	task.spawn(pressAnim, openBtn)
	openPanel()
end)

-- =========================
-- Drag panel (mouse + touch)
-- =========================
do
	local draggingWindow = false
	local dragStart = Vector2.zero
	local startPos = UDim2.new()

	titleBar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			draggingWindow = true
			dragStart = input.Position
			startPos = main.Position

			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					draggingWindow = false
				end
			end)
		end
	end)

	titleBar.InputChanged:Connect(function(input)
		if not draggingWindow then
			return
		end
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			local delta = input.Position - dragStart
			main.Position = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + delta.X,
				startPos.Y.Scale, startPos.Y.Offset + delta.Y
			)
			if openBtn.Visible then
				openBtn.Position = main.Position
			end
		end
	end)
end

-- Keep working after camera changes in some places
workspace:GetPropertyChangedSignal("CurrentCamera"):Connect(function()
	camera = workspace.CurrentCamera
	if camera then
		camera.FieldOfView = currentFov
	end
end)

-- Init
setFov(DEFAULT_FOV)
