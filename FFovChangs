-- =========================
-- Helpers
-- =========================
local function clamp(v, minV, maxV)
	return math.max(minV, math.min(maxV, v))
end

local function isTouchDevice()
	return UserInputService.TouchEnabled
end

local function createCorner(parent, radius)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius)
	c.Parent = parent
	return c
end

local function pressAnim(btn)
	local originalSize = btn.Size
	local downSize = UDim2.new(
		originalSize.X.Scale, originalSize.X.Offset - 2,
		originalSize.Y.Scale, originalSize.Y.Offset - 2
	)

	local down = TweenService:Create(btn, TweenInfo.new(0.07), {Size = downSize})
	local up = TweenService:Create(btn, TweenInfo.new(0.07), {Size = originalSize})
	down:Play()
	down.Completed:Wait()
	up:Play()
end

